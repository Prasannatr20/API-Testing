  "item": [
    {
      "name": "POST",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "pm.environment.set(\"productId\", jsonData.id);\r",
              "pm.test(\"Status code is 201\", function ()\r",
              "{\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "pm.test(\"Response time less than 500\", function()\r",
              "{\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});\r",
              "pm.test(\"Content-Type header exists\", function ()\r",
              "{\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "});\r",
              "pm.test(\"Contains Content-Type application/json\", function ()\r",
              "{\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "//Accessing header value\r",
              "var header = pm.response.headers.get(\"Content-Type\");\r",
              "console.log(header);\r",
              "//Checking a headre is not present(Useful for security checks)\r",
              "pm.test(\"Response should not expose server header\", function ()\r",
              "{\r",
              "    pm.expect(pm.response.headers.has(\"Server\")).to.eql(false);\r",
              "});\r",
              "//Validating a anumber header\r",
              "// pm.test(\"Rate limit remainng is above 0\", function()\r",
              "// {\r",
              "//     var remainng=parseInt(pm.response.headers.get(\"X-RateLimit-Remaining\"));\r",
              "//     pm.expect(remainng).to.be.above(0);\r",
              "// });\r",
              "//Printing aal the headers\r",
              "pm.response.headers.each(function (header)\r",
              "{\r",
              "    console.log(header.key + \": \" + header.value);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"productName\": \"Screen\",\r\n    \"price\": 500,\r\n    \"inStock\": false\r\n}"
        },
        "url": {
          "raw": "http://localhost:3000/products",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "products"
          ]
        }
      },
      "response": []
