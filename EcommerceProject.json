              "});\r",
              "pm.test(\"content-type header has application/json\", function()\r",
              "{\r",
              "    pm.expect(pm.response.headers.get(\"content-type\")).to.include(\"application/json\");\r",
              "});\r",
              "var jsonData= pm.response.json();\r",
              "pm.test(\"Product exists\", function()\r",
              "{\r",
              "    pm.expect(jsonData.products.length).to.be.above(0);\r",
              "});\r",
              "pm.test(\"Product title is correct\", function()\r",
              "{\r",
              "    pm.expect(jsonData.products[0].title).to.eql(\"Essence Mascara Lash Princess\");\r",
              "});\r",
              "pm.test(\"Product price is a number\", function()\r",
              "{\r",
              "    pm.expect(pm.response.json().products[0].price).to.be.a(\"number\");\r",
              "});\r",
              "pm.environment.set(\"productId\", jsonData.products[0].id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
